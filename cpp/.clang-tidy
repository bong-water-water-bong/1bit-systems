# clang-tidy configuration for 1bit-systems C++23 port.
#
# Adopted 2026-04-26: full ISO C++ Core Guidelines checkset, plus the
# adjacent diagnostic families (bugprone / cert / clang-analyzer / misc /
# modernize / performance / portability / readability).
#
# Stabilization policy: WarningsAsErrors is empty — clang-tidy warns,
# build does not fail. Once the back-catalog is clean we will flip
# selected checks into the error class one at a time.
#
# HeaderFilterRegex restricts diagnostics to OUR headers only; FetchContent
# trees under build/_deps/ and third_party/ are skipped.

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  cppcoreguidelines-*,
  misc-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers,
  -modernize-use-trailing-return-type,
  -cppcoreguidelines-pro-bounds-pointer-arithmetic,
  -cppcoreguidelines-avoid-non-const-global-variables,
  -cppcoreguidelines-pro-type-reinterpret-cast,
  -cppcoreguidelines-avoid-do-while,
  -readability-identifier-length,
  -misc-include-cleaner,
  -modernize-use-nodiscard,
  -bugprone-easily-swappable-parameters,
  -readability-function-cognitive-complexity,
  -cppcoreguidelines-non-private-member-variables-in-classes,
  -misc-non-private-member-variables-in-classes,
  cppcoreguidelines-pro-type-cstyle-cast,
  cppcoreguidelines-special-member-functions

WarningsAsErrors: ''

# Audit only our crates. Build trees, FetchContent _deps, and third_party/
# are explicitly excluded so we do not spam upstream issues.
HeaderFilterRegex: '^.*/cpp/(core|mcp|cli|landing|power|voice|echo|helm|helm-tui|watchdog|halo-ralph|mcp-clients|mcp-linuxgsm|onnx|kokoro|aie|stream|ingest|retrieval|tier-mint|tools)/.*\.hpp$'

FormatStyle: file

CheckOptions:
  # I.27: enforce rule-of-five symmetry. Special members must be all-or-none.
  - key:   cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor
    value: 'true'
  - key:   cppcoreguidelines-special-member-functions.AllowMissingMoveFunctions
    value: 'false'
  - key:   cppcoreguidelines-special-member-functions.AllowMissingMoveFunctionsWhenCopyIsDeleted
    value: 'true'

  # NL.10 / NL.11: project naming. struct + class are types; functions and
  # locals are lower_case; constants and macros are UPPER_CASE.
  - key:   readability-identifier-naming.ClassCase
    value: CamelCase
  - key:   readability-identifier-naming.StructCase
    value: CamelCase
  - key:   readability-identifier-naming.EnumCase
    value: CamelCase
  - key:   readability-identifier-naming.FunctionCase
    value: lower_case
  - key:   readability-identifier-naming.VariableCase
    value: lower_case
  - key:   readability-identifier-naming.ParameterCase
    value: lower_case
  - key:   readability-identifier-naming.PrivateMemberSuffix
    value: '_'
  - key:   readability-identifier-naming.ProtectedMemberSuffix
    value: '_'
  - key:   readability-identifier-naming.ConstexprVariableCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.GlobalConstantCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.MacroDefinitionCase
    value: UPPER_CASE
  - key:   readability-identifier-naming.NamespaceCase
    value: lower_case

  # F.16: pass cheaply-copied params by value. Arbitrary 16-byte threshold
  # matches the std::string_view + two-pointer-pair sweet spot.
  - key:   performance-unnecessary-value-param.AllowedTypes
    value: 'std::string_view;std::span'

  # ES.20: always initialize objects. Be strict about scalars.
  - key:   cppcoreguidelines-init-variables.IncludeStyle
    value: llvm

  # CP.20 (cert-oop54): self-assign check style.
  - key:   cert-oop54-cpp.WarnOnlyIfThisHasSuspiciousField
    value: 'false'

  # bugprone-unchecked-optional-access: surface unwraps without value() guard.
  - key:   bugprone-unchecked-optional-access.IgnoreSmartPointerDereference
    value: 'false'
