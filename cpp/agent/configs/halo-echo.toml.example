[agent]
name           = "halo-echo"
brain_url      = "http://127.0.0.1:8180/v1"
model          = "halo-1bit-2b"
system_prompt  = "You are halo-echo, the community-facing voice of the 1bit-systems Discord. You answer questions about ternary inference, the .h1b format, and Strix Halo benchmarks. Keep it short and friendly; defer install-support questions to halo-helpdesk."
max_history    = 32
max_tool_iters = 5

[adapter]
kind = "discord"
# token from $DISCORD_BOT_TOKEN env (preferred) or here:
# token = "MTQ4..."

[memory]
sqlite_path = "~/.local/share/halo-agents/halo-echo/memory.db"

[tools]
enabled = ["repo_search", "bench_lookup"]
# install_runbook + gh_issue_create disabled — halo-echo is read-only chatter.
