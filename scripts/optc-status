#!/usr/bin/env bash
# Report Strix Halo OPTC mitigation state.

set -euo pipefail

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
CYAN='\033[0;36m'; NC='\033[0m'

ok() { printf '%b✓%b %s\n' "$GREEN" "$NC" "$*"; }
warn() { printf '%b!%b %s\n' "$YELLOW" "$NC" "$*"; }
fail() { printf '%b✗%b %s\n' "$RED" "$NC" "$*"; }
say() { printf '%b▸%b %s\n' "$CYAN" "$NC" "$*"; }

say "kernel"
uname -a

say "cmdline"
if tr ' ' '\n' </proc/cmdline | grep -qx 'amdgpu.dcdebugmask=0x410'; then
    ok "amdgpu.dcdebugmask=0x410 active"
else
    fail "amdgpu.dcdebugmask=0x410 not active in this boot"
fi

say "bootloader config"
if [[ -f /etc/default/limine ]]; then
    if grep -q 'amdgpu.dcdebugmask=0x410' /etc/default/limine; then
        ok "/etc/default/limine has amdgpu.dcdebugmask=0x410 staged"
    else
        warn "/etc/default/limine does not stage amdgpu.dcdebugmask=0x410"
    fi
else
    warn "/etc/default/limine not found"
fi

say "amdgpu OPTC events in current boot"
hits=$(journalctl -k -b --no-pager 2>/dev/null | grep -Eci 'REG_WAIT.*optc35_disable_crtc|optc35_disable_crtc' || true)
if (( hits == 0 )); then
    ok "no optc35_disable_crtc events in current boot"
else
    fail "$hits optc35_disable_crtc event(s) in current boot"
    journalctl -k -b --no-pager 2>/dev/null | grep -Ei 'REG_WAIT.*optc35_disable_crtc|optc35_disable_crtc' | tail -10
fi

say "GPU performance level"
found=0
for f in /sys/class/drm/card*/device/power_dpm_force_performance_level; do
    [[ -e "$f" ]] || continue
    found=1
    printf '%s: %s\n' "$f" "$(cat "$f")"
done
(( found )) || warn "no power_dpm_force_performance_level file found"

say "service"
if systemctl status 1bit-optc-gpu-perf.service >/dev/null 2>&1; then
    systemctl --no-pager --full status 1bit-optc-gpu-perf.service || true
else
    warn "1bit-optc-gpu-perf.service is not installed"
fi
