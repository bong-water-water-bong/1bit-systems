#!/usr/bin/env bash
# 1bit — control plane for the 1bit-systems lean 1-bit inference engine.
#
# Subcommands:
#   1bit up            start lemond + flm + proxy; open browser; launch GAIA
#   1bit down          stop all three
#   1bit status        show lemond / flm / proxy status
#   1bit pull <model>  pull a model (auto-routes: NPU via flm, GPU via lemonade)
#   1bit bench         run the 1-bit / ternary pile bench
#   1bit npu [model]   start FLM NPU server (default: qwen3:0.6b)
#   1bit gaia          manage AMD GAIA agent UI / API / MCP

set -euo pipefail

# Brand palette mirrors 1bit-site/assets/style.css (truecolor — terminal-theme-independent).
CYAN='\033[38;2;0;212;255m'    # #00d4ff — --accent
GREEN='\033[38;2;46;160;67m'   # #2ea043 — success
YELLOW='\033[38;2;240;180;41m' # #f0b429 — --warn-fg
RED='\033[38;2;248;81;73m'     # #f85149 — danger
NC='\033[0m'
say()  { printf '%b▸%b %s\n' "$CYAN" "$NC" "$*"; }
ok()   { printf '%b✓%b %s\n' "$GREEN" "$NC" "$*"; }
warn() { printf '%b!%b %s\n' "$YELLOW" "$NC" "$*"; }
die()  { printf '%b✗%b %s\n' "$RED" "$NC" "$*" >&2; exit 1; }

LEMOND_URL="http://127.0.0.1:13305"
PROXY_URL="http://127.0.0.1:13306"
WEBUI_URL="http://127.0.0.1:3000"
LEMOND_LOG=/tmp/lemond.log
FLM_LOG=/tmp/flm-serve.log
PROXY_LOG=/tmp/1bit-proxy.log
WEBUI_LOG=/tmp/1bit-webui.log
GAIA_LOG="${HOME}/.gaia/gaia.log"
GAIA_ELECTRON_LOG="${HOME}/.gaia/electron-main.log"
GAIA_APPIMAGE="${GAIA_APPIMAGE:-${HOME}/Applications/gaia-agent-ui.AppImage}"
DEFAULT_NPU_MODEL="${ONEBIT_NPU_MODEL:-qwen3:1.7b}"
DEFAULT_FLM_FLAGS="${ONEBIT_FLM_FLAGS:---port 52625 --embed 1 --socket 20 --q-len 20}"
GAIA_BASE_URL="${GAIA_BASE_URL:-$PROXY_URL/api/v1}"
LEMOND_HOST="${ONEBIT_LEMOND_HOST:-127.0.0.1}"
PROXY_HOST="${PROXY_HOST:-127.0.0.1}"
WEBUI_HOST="${ONEBIT_WEBUI_HOST:-127.0.0.1}"
ONEBIT_CONFIG_DIR="${ONEBIT_CONFIG_DIR:-$HOME/.config/1bit-systems}"
ONEBIT_TOOLBOX_ENV="${ONEBIT_TOOLBOX_ENV:-$ONEBIT_CONFIG_DIR/toolbox.env}"

load_toolbox_env() {
    if [[ -r "$ONEBIT_TOOLBOX_ENV" ]]; then
        # shellcheck disable=SC1090
        . "$ONEBIT_TOOLBOX_ENV"
    fi
    ONEBIT_TOOLBOX_NAME="${ONEBIT_TOOLBOX_NAME:-1bit-llama-vulkan}"
    ONEBIT_TOOLBOX_IMAGE="${ONEBIT_TOOLBOX_IMAGE:-docker.io/kyuz0/amd-strix-halo-toolboxes:vulkan-radv}"
    ONEBIT_TOOLBOX_BACKEND="${ONEBIT_TOOLBOX_BACKEND:-auto}"
    ONEBIT_TOOLBOX_MODEL="${ONEBIT_TOOLBOX_MODEL:-}"
    ONEBIT_TOOLBOX_CTX="${ONEBIT_TOOLBOX_CTX:-8192}"
    ONEBIT_TOOLBOX_NGL="${ONEBIT_TOOLBOX_NGL:-999}"
    ONEBIT_TOOLBOX_HOST="${ONEBIT_TOOLBOX_HOST:-127.0.0.1}"
    ONEBIT_TOOLBOX_PORT="${ONEBIT_TOOLBOX_PORT:-13305}"
}

# Locate the proxy script in the repo or installed location.
proxy_script() {
    local self_dir
    self_dir="$(dirname "$(readlink -f "$0")")"
    if [[ -f "$self_dir/1bit-proxy.js" ]]; then
        echo "$self_dir/1bit-proxy.js"
    elif [[ -f /usr/local/share/1bit-systems/1bit-proxy.js ]]; then
        echo /usr/local/share/1bit-systems/1bit-proxy.js
    elif [[ -f /usr/share/1bit-systems/1bit-proxy.js ]]; then
        echo /usr/share/1bit-systems/1bit-proxy.js
    elif [[ -f /home/bcloud/1bit-systems/scripts/1bit-proxy.js ]]; then
        echo /home/bcloud/1bit-systems/scripts/1bit-proxy.js
    else
        echo ""
    fi
}

gaia_cli() {
    local cand
    for cand in \
        "${HOME}/.gaia/venv/bin/gaia" \
        "${HOME}/.local/bin/gaia" \
        "$(command -v gaia 2>/dev/null || true)"
    do
        [[ -n "$cand" && -x "$cand" ]] && { echo "$cand"; return 0; }
    done
    return 1
}

gaia_ui_url() {
    local port
    port="$(ss -ltnp 2>/dev/null | awk '/gaia/ && /127[.]0[.]0[.]1:/ {
        sub(/.*127[.]0[.]0[.]1:/, "", $4); sub(/ .*/, "", $4); print $4; exit
    }')"
    [[ -n "$port" ]] && echo "http://127.0.0.1:$port"
}

start_gaia() {
    if pgrep -f 'gaia-agent-ui.AppImage|/\.gaia/venv/bin/gaia chat --ui' >/dev/null 2>&1; then
        local url
        url="$(gaia_ui_url || true)"
        ok "GAIA already running${url:+ at $url}"
        return
    fi

    if [[ -x "$GAIA_APPIMAGE" ]]; then
        say "Launching AMD GAIA Agent UI ($GAIA_APPIMAGE)"
        GAIA_BASE_URL="$GAIA_BASE_URL" nohup "$GAIA_APPIMAGE" --no-sandbox >/dev/null 2>&1 &
        return
    fi

    local gaia
    gaia="$(gaia_cli || true)"
    [[ -n "$gaia" ]] || { warn "GAIA not found. Install from https://amd-gaia.ai/docs/quickstart and point it at $GAIA_BASE_URL"; return; }
    say "Launching AMD GAIA web UI against $GAIA_BASE_URL"
    nohup "$gaia" chat --ui --base-url "$GAIA_BASE_URL" >"$GAIA_LOG" 2>&1 &
}

stop_gaia() {
    local stopped=0
    if pgrep -f 'gaia-agent-ui.AppImage|/\.gaia/venv/bin/gaia chat --ui|/\.gaia-desktop-bin' >/dev/null 2>&1; then
        pkill -f 'gaia-agent-ui.AppImage|/\.gaia/venv/bin/gaia chat --ui|/\.gaia-desktop-bin' 2>/dev/null || true
        stopped=1
    fi
    [[ "$stopped" -eq 1 ]] && ok "GAIA stopped" || ok "GAIA already stopped"
}

# -- service controls -----------------------------------------------------

start_lemond() {
    if pgrep -x lemond >/dev/null 2>&1; then
        ok "lemond already running"
        return
    fi
    say "Starting lemond on ${LEMOND_HOST}:13305"
    nohup lemond --host "$LEMOND_HOST" >"$LEMOND_LOG" 2>&1 &
    # wait up to ~10s for it to come up
    for _ in $(seq 1 20); do
        sleep 0.5
        curl -s --max-time 1 "$LEMOND_URL/v1/models" >/dev/null 2>&1 && { ok "lemond up at $LEMOND_URL"; return; }
    done
    warn "lemond didn't respond — see $LEMOND_LOG"
}

start_flm() {
    if pgrep -f 'flm.*serve' >/dev/null 2>&1; then
        ok "flm already serving (pid $(pgrep -f 'flm.*serve' | head -1))"
        return
    fi
    say "Starting flm serve $DEFAULT_NPU_MODEL"
    # shellcheck disable=SC2086 # flags intentionally split like normal CLI args
    nohup flm serve "$DEFAULT_NPU_MODEL" $DEFAULT_FLM_FLAGS >"$FLM_LOG" 2>&1 &
    sleep 4
    local port
    port="$(flm port 2>/dev/null | awk '{print $NF}')"
    if [[ -n "$port" ]]; then
        ok "flm serving $DEFAULT_NPU_MODEL on :$port (flags: $DEFAULT_FLM_FLAGS)"
    else
        warn "flm didn't report a port — see $FLM_LOG"
    fi
}

start_proxy() {
    if pgrep -f '1bit-proxy.js' >/dev/null 2>&1; then
        ok "proxy already running"
        return
    fi
    local script
    script="$(proxy_script)"
    [[ -z "$script" ]] && { warn "proxy script not found, skipping"; return; }
    command -v node >/dev/null 2>&1 || { warn "node not found, skipping proxy"; return; }
    say "Starting 1bit-proxy on ${PROXY_HOST}:13306 (unifies lemond + flm)"
    PROXY_HOST="$PROXY_HOST" nohup node "$script" >"$PROXY_LOG" 2>&1 &
    sleep 1
    if curl -s --max-time 2 "$PROXY_URL/health" >/dev/null 2>&1; then
        ok "proxy up at $PROXY_URL — single OpenAI endpoint, both lanes"
    else
        warn "proxy didn't respond — see $PROXY_LOG"
    fi
}

cmd_up() {
    if should_use_toolbox_default; then
        cmd_toolbox up
        start_proxy
        echo
        ok "All up. Endpoints:"
        printf '   Unified (recommended):  %s/v1/\n' "$PROXY_URL"
        printf '   Toolbox llama.cpp:      http://127.0.0.1:%s/v1/\n' "${ONEBIT_TOOLBOX_PORT:-13305}"
        return
    fi

    start_lemond
    start_flm
    start_proxy

    say "Opening browser: $PROXY_URL  (1bit.systems home)"
    xdg-open "$PROXY_URL" >/dev/null 2>&1 &

    start_gaia

    echo
    ok "All up. Endpoints:"
    printf '   Unified (recommended):  %s/v1/\n' "$PROXY_URL"
    printf '   Lemonade (GPU only):    %s/v1/\n' "$LEMOND_URL"
    printf '   FLM (NPU only):         http://127.0.0.1:%s/v1/\n' "$(flm port 2>/dev/null | awk '{print $NF}')"
}

cmd_down() {
    say "Stopping all services"
    stop_gaia
    pkill -f '1bit-proxy.js' 2>/dev/null && ok "proxy stopped" || ok "proxy already stopped"
    pkill -f 'flm.*serve' 2>/dev/null && ok "flm stopped" || ok "flm already stopped"
    pkill -x lemond 2>/dev/null && ok "lemond stopped" || ok "lemond already stopped"
}

cmd_status() {
    if curl -s --max-time 2 "$LEMOND_URL/v1/models" >/dev/null 2>&1; then
        ok "lemond:  up at $LEMOND_URL"
    else
        warn "lemond:  down"
    fi

    if pgrep -f 'flm.*serve' >/dev/null 2>&1; then
        local port
        port="$(flm port 2>/dev/null | awk '{print $NF}')"
        ok "flm:     serving on :$port"
        [[ "$port" == "52625" ]] || warn "flm:     expected :52625 for stack parity"
    else
        warn "flm:     not serving"
    fi

    if curl -s --max-time 2 "$PROXY_URL/health" >/dev/null 2>&1; then
        local n
        n="$(curl -s --max-time 2 "$PROXY_URL/health" | grep -oE '"models":[0-9]+' | grep -oE '[0-9]+')"
        ok "proxy:   up at $PROXY_URL ($n models unified)"
    else
        warn "proxy:   down"
    fi

    local gaia_url
    gaia_url="$(gaia_ui_url || true)"
    if pgrep -f 'gaia-agent-ui.AppImage|/\.gaia/venv/bin/gaia chat --ui' >/dev/null 2>&1; then
        ok "gaia:    up${gaia_url:+ at $gaia_url}"
    else
        warn "gaia:    down"
    fi

    echo
    echo "memlock limit: $(ulimit -l)"
}

cmd_doctor() {
    say "host"
    if [[ -r /etc/os-release ]]; then
        # shellcheck disable=SC1091
        . /etc/os-release
        printf '   distro: %s\n' "${PRETTY_NAME:-unknown}"
    else
    printf '   distro: unknown\n'
    fi
    printf '   kernel: %s\n' "$(uname -r)"
    printf '   user:   %s\n' "$(id -un)"
    printf '   active groups:     %s\n' "$(id -Gn)"
    printf '   configured groups: %s\n' "$(id -nG "$(id -un)" 2>/dev/null || id -Gn)"
    if ! id -Gn | tr ' ' '\n' | grep -qx render && id -nG "$(id -un)" 2>/dev/null | tr ' ' '\n' | grep -qx render; then
        warn "render group is configured but not active in this shell; log out and back in or reboot"
    fi

    echo
    say "gpu devices"
    for dev in /dev/dri /dev/kfd /dev/accel/accel0; do
        if [[ -e "$dev" ]]; then
            ok "$dev present"
            ls -ld "$dev" 2>/dev/null || true
        else
            warn "$dev missing"
        fi
    done
    if [[ -d /sys/class/drm ]]; then
        printf '   sysfs drm: %s\n' "$(find /sys/class/drm -maxdepth 1 -mindepth 1 -printf '%f ' 2>/dev/null)"
    fi

    echo
    say "runtime tools"
    for tool in pacman apt podman toolbox distrobox rocminfo clinfo vulkaninfo llama-server lemond flm node; do
        if command -v "$tool" >/dev/null 2>&1; then
            ok "$tool: $(command -v "$tool")"
        else
            warn "$tool: not found"
        fi
    done

    echo
    say "backend endpoints"
    if curl -s --max-time 2 "$LEMOND_URL/v1/models" >/dev/null 2>&1; then
        ok "OpenAI backend at $LEMOND_URL/v1"
    else
        warn "no OpenAI backend at $LEMOND_URL/v1"
    fi
    if curl -s --max-time 2 "$PROXY_URL/health" >/dev/null 2>&1; then
        ok "1bit-proxy at $PROXY_URL"
    else
        warn "1bit-proxy down"
    fi

    echo
    say "toolbox hint"
    load_toolbox_env
    printf '   config: %s\n' "$ONEBIT_TOOLBOX_ENV"
    printf '   image:  %s\n' "$ONEBIT_TOOLBOX_IMAGE"
    printf '   name:   %s\n' "$ONEBIT_TOOLBOX_NAME"
    [[ -n "$ONEBIT_TOOLBOX_MODEL" ]] && printf '   model:  %s\n' "$ONEBIT_TOOLBOX_MODEL" || warn "ONEBIT_TOOLBOX_MODEL is not set"
    if [[ ! -e /dev/dri || ! -e /dev/kfd ]]; then
        warn "GPU compute device nodes are not visible in this shell/container."
        printf '   Fix host access first, then create toolboxes with --device /dev/dri --device /dev/kfd.\n'
    fi
    if command -v apt >/dev/null 2>&1 && ! command -v pacman >/dev/null 2>&1; then
        printf '   Native install.sh is not the right path on Ubuntu today.\n'
        printf '   See docs/toolbox-backends.md for Strix Halo toolbox-backed backends.\n'
    fi
}

toolbox_engine() {
    load_toolbox_env
    case "$ONEBIT_TOOLBOX_BACKEND" in
        distrobox|toolbox) printf '%s\n' "$ONEBIT_TOOLBOX_BACKEND"; return 0 ;;
        auto|"") ;;
        *) die "unknown ONEBIT_TOOLBOX_BACKEND=$ONEBIT_TOOLBOX_BACKEND (use auto, distrobox, or toolbox)" ;;
    esac
    if command -v distrobox >/dev/null 2>&1; then
        printf 'distrobox\n'
    elif command -v toolbox >/dev/null 2>&1; then
        printf 'toolbox\n'
    else
        return 1
    fi
}

toolbox_exists() {
    load_toolbox_env
    podman container exists "$ONEBIT_TOOLBOX_NAME" >/dev/null 2>&1
}

toolbox_exec() {
    local engine="$1"
    shift
    case "$engine" in
        distrobox) distrobox enter "$ONEBIT_TOOLBOX_NAME" -- "$@" ;;
        toolbox) toolbox run --container "$ONEBIT_TOOLBOX_NAME" "$@" ;;
        *) return 1 ;;
    esac
}

should_use_toolbox_default() {
    load_toolbox_env
    [[ "${ONEBIT_BACKEND:-}" == "toolbox" ]] && return 0
    command -v pacman >/dev/null 2>&1 && [[ "${ONEBIT_BACKEND:-}" != "toolbox" ]] && return 1
    [[ -r "$ONEBIT_TOOLBOX_ENV" ]] && return 0
    ! command -v lemond >/dev/null 2>&1 && ! command -v flm >/dev/null 2>&1 && return 0
    return 1
}

cmd_toolbox_status() {
    load_toolbox_env
    local engine
    engine="$(toolbox_engine 2>/dev/null || true)"
    say "toolbox backend"
    printf '   engine: %s\n' "${engine:-missing distrobox/toolbox}"
    printf '   name:   %s\n' "$ONEBIT_TOOLBOX_NAME"
    printf '   image:  %s\n' "$ONEBIT_TOOLBOX_IMAGE"
    printf '   config: %s\n' "$ONEBIT_TOOLBOX_ENV"
    [[ -n "$ONEBIT_TOOLBOX_MODEL" ]] && printf '   model:  %s\n' "$ONEBIT_TOOLBOX_MODEL" || warn "model not set; export ONEBIT_TOOLBOX_MODEL=/path/to/model.gguf"
    if command -v podman >/dev/null 2>&1 && toolbox_exists; then
        ok "container exists"
        podman ps --filter "name=^${ONEBIT_TOOLBOX_NAME}$" --format '   running: {{.Status}}' 2>/dev/null || true
    else
        warn "container not created"
    fi
    if curl -s --max-time 2 "http://127.0.0.1:${ONEBIT_TOOLBOX_PORT}/v1/models" >/dev/null 2>&1; then
        ok "llama.cpp backend up at http://127.0.0.1:${ONEBIT_TOOLBOX_PORT}/v1"
    else
        warn "llama.cpp backend down at :${ONEBIT_TOOLBOX_PORT}"
    fi
}

cmd_toolbox_list() {
    cat <<EOF
1bit toolbox lanes

Default inference:
  llama-radv     docker.io/kyuz0/amd-strix-halo-toolboxes:vulkan-radv
                 Stable llama.cpp GGUF serving. 1bit default on Ubuntu/Fedora.

Performance inference:
  llama-rocm     docker.io/kyuz0/amd-strix-halo-toolboxes:rocm-7.2.2
                 ROCm llama.cpp after host /dev/dri and /dev/kfd are stable.

High-throughput serving:
  vllm           docker.io/kyuz0/vllm-therock-gfx1151:stable
                 vLLM OpenAI endpoint, usually on :8000.

Image/video:
  comfyui        docker.io/kyuz0/amd-strix-halo-comfyui:latest
                 ComfyUI workflows and model manager.

Training:
  finetune       docker.io/kyuz0/amd-strix-halo-llm-finetuning:latest
                 Jupyter fine-tuning workspace.

References:
  https://github.com/kyuz0/amd-strix-halo-toolboxes
  https://github.com/kyuz0/amd-strix-halo-vllm-toolboxes
  https://github.com/kyuz0/amd-strix-halo-comfyui-toolboxes
  https://github.com/kyuz0/amd-strix-halo-llm-finetuning
EOF
}

cmd_toolbox_commands() {
    local lane="${1:-llama-radv}"
    case "$lane" in
        llama-radv)
            cat <<EOF
# llama.cpp RADV/Vulkan: most compatible first inference lane
ONEBIT_TOOLBOX_IMAGE=docker.io/kyuz0/amd-strix-halo-toolboxes:vulkan-radv \\
ONEBIT_TOOLBOX_NAME=1bit-llama-vulkan \\
  1bit toolbox bootstrap

ONEBIT_TOOLBOX_MODEL=/path/to/model.gguf 1bit toolbox up
1bit up
EOF
            ;;
        llama-rocm)
            cat <<EOF
# llama.cpp ROCm: performance lane after /dev/kfd is working
ONEBIT_TOOLBOX_IMAGE=docker.io/kyuz0/amd-strix-halo-toolboxes:rocm-7.2.2 \\
ONEBIT_TOOLBOX_NAME=1bit-llama-rocm \\
  1bit toolbox bootstrap

ONEBIT_TOOLBOX_MODEL=/path/to/model.gguf \\
ONEBIT_TOOLBOX_NAME=1bit-llama-rocm \\
  1bit toolbox up
EOF
            ;;
        vllm)
            cat <<EOF
# vLLM toolbox: high-throughput OpenAI-compatible serving
# Fedora:
toolbox create vllm \\
  --image docker.io/kyuz0/vllm-therock-gfx1151:stable \\
  -- --device /dev/dri --device /dev/kfd \\
     --group-add video --group-add render --security-opt seccomp=unconfined
toolbox enter vllm
start-vllm

# Ubuntu:
distrobox create -n vllm \\
  --image docker.io/kyuz0/vllm-therock-gfx1151:stable \\
  --additional-flags "--device /dev/kfd --device /dev/dri --group-add video --group-add render --security-opt seccomp=unconfined"
distrobox enter vllm
start-vllm

# After vLLM is serving:
LEMOND_URL=http://127.0.0.1:8000 node "$(proxy_script)"
EOF
            ;;
        comfyui)
            cat <<EOF
# ComfyUI toolbox: image/video generation lane
toolbox create strix-halo-comfyui \\
  --image docker.io/kyuz0/amd-strix-halo-comfyui:latest \\
  -- --device /dev/dri --device /dev/kfd \\
     --group-add video --group-add render --security-opt seccomp=unconfined
toolbox enter strix-halo-comfyui
/opt/set_extra_paths.sh
model_manager
start_comfy_ui
EOF
            ;;
        finetune)
            cat <<EOF
# Fine-tuning toolbox: training/Jupyter lane
toolbox create strix-halo-llm-finetuning \\
  --image docker.io/kyuz0/amd-strix-halo-llm-finetuning:latest \\
  -- --device /dev/dri --device /dev/kfd \\
     --group-add video --group-add render --security-opt seccomp=unconfined
toolbox enter strix-halo-llm-finetuning
mkdir -p ~/finetuning-workspace
cp -r /opt/workspace ~/finetuning-workspace/
jupyter lab --notebook-dir ~/finetuning-workspace/
EOF
            ;;
        *)
            die "usage: 1bit toolbox commands [llama-radv|llama-rocm|vllm|comfyui|finetune]"
            ;;
    esac
}

cmd_toolbox_bootstrap() {
    load_toolbox_env
    command -v podman >/dev/null 2>&1 || die "podman not found. Ubuntu: sudo apt install podman distrobox nodejs curl. Fedora: sudo dnf install podman toolbox nodejs curl."
    local engine
    engine="$(toolbox_engine)" || die "distrobox/toolbox not found. Ubuntu: install distrobox. Fedora: install toolbox."
    if [[ ! -e /dev/dri ]]; then
        die "/dev/dri missing; fix host GPU device visibility before creating the toolbox. Check groups video/render, udev rules, and whether this shell is inside a container."
    fi
    if [[ "$ONEBIT_TOOLBOX_IMAGE" == *rocm* && ! -e /dev/kfd ]]; then
        die "/dev/kfd missing; ROCm toolbox cannot use HIP/ROCm from this environment. Use the Vulkan image or fix KFD access first."
    fi
    if toolbox_exists; then
        ok "toolbox already exists: $ONEBIT_TOOLBOX_NAME"
        return
    fi

    say "Creating $engine backend $ONEBIT_TOOLBOX_NAME from $ONEBIT_TOOLBOX_IMAGE"
    case "$engine" in
        distrobox)
            distrobox create --yes \
                --name "$ONEBIT_TOOLBOX_NAME" \
                --image "$ONEBIT_TOOLBOX_IMAGE" \
                --additional-flags "--device /dev/dri --device /dev/kfd --group-add video --group-add render --security-opt seccomp=unconfined"
            ;;
        toolbox)
            toolbox create "$ONEBIT_TOOLBOX_NAME" \
                --image "$ONEBIT_TOOLBOX_IMAGE" \
                -- --device /dev/dri --device /dev/kfd \
                   --group-add video --group-add render \
                   --security-opt seccomp=unconfined
            ;;
    esac
    ok "toolbox created. Set ONEBIT_TOOLBOX_MODEL, then run: 1bit toolbox up"
}

cmd_toolbox_up() {
    load_toolbox_env
    local engine model
    engine="$(toolbox_engine)" || die "distrobox/toolbox not found"
    toolbox_exists || cmd_toolbox_bootstrap
    model="${1:-$ONEBIT_TOOLBOX_MODEL}"
    [[ -n "$model" ]] || die "model path required. Use: ONEBIT_TOOLBOX_MODEL=/path/to/model.gguf 1bit toolbox up"
    [[ -f "$model" ]] || warn "model path is not visible on the host: $model. It must also be visible inside the toolbox."
    if curl -s --max-time 2 "http://127.0.0.1:${ONEBIT_TOOLBOX_PORT}/v1/models" >/dev/null 2>&1; then
        ok "toolbox llama.cpp already serving at :$ONEBIT_TOOLBOX_PORT"
        return
    fi
    say "Starting toolbox llama-server on ${ONEBIT_TOOLBOX_HOST}:${ONEBIT_TOOLBOX_PORT}"
    local cmd=()
    case "$engine" in
        distrobox) cmd=(distrobox enter "$ONEBIT_TOOLBOX_NAME" -- llama-server --host "$ONEBIT_TOOLBOX_HOST" --port "$ONEBIT_TOOLBOX_PORT" -m "$model" -c "$ONEBIT_TOOLBOX_CTX" -ngl "$ONEBIT_TOOLBOX_NGL" -fa 1 --no-mmap) ;;
        toolbox) cmd=(toolbox run --container "$ONEBIT_TOOLBOX_NAME" llama-server --host "$ONEBIT_TOOLBOX_HOST" --port "$ONEBIT_TOOLBOX_PORT" -m "$model" -c "$ONEBIT_TOOLBOX_CTX" -ngl "$ONEBIT_TOOLBOX_NGL" -fa 1 --no-mmap) ;;
    esac
    nohup "${cmd[@]}" >"$LEMOND_LOG" 2>&1 &
    for _ in $(seq 1 30); do
        sleep 1
        curl -s --max-time 1 "http://127.0.0.1:${ONEBIT_TOOLBOX_PORT}/v1/models" >/dev/null 2>&1 && { ok "toolbox backend up at http://127.0.0.1:${ONEBIT_TOOLBOX_PORT}/v1"; return; }
    done
    warn "toolbox backend did not respond — see $LEMOND_LOG"
}

cmd_toolbox_down() {
    load_toolbox_env
    pkill -f "llama-server.*${ONEBIT_TOOLBOX_PORT}" 2>/dev/null && ok "toolbox llama-server stopped" || ok "toolbox llama-server already stopped"
}

cmd_toolbox() {
    local action="${1:-status}"
    shift || true
    case "$action" in
        list|refs) cmd_toolbox_list ;;
        commands|cmd) cmd_toolbox_commands "$@" ;;
        bootstrap|create) cmd_toolbox_bootstrap ;;
        up|start) cmd_toolbox_up "$@" ;;
        down|stop) cmd_toolbox_down ;;
        status) cmd_toolbox_status ;;
        *) die "usage: 1bit toolbox [list|commands|bootstrap|up|down|status]" ;;
    esac
}

cmd_pull() {
    local model="${1:-}"
    [[ -z "$model" ]] && die "usage: 1bit pull <model>"
    if flm list 2>/dev/null | grep -q "^[[:space:]]*-[[:space:]]*${model}[[:space:]]"; then
        say "Routing to FLM (NPU): $model"
        flm pull "$model"
    else
        say "Routing to lemonade (GPU): $model"
        lemonade pull "$model"
    fi
}

cmd_bench() {
    local self_dir script
    self_dir="$(dirname "$(readlink -f "$0")")"
    for cand in \
        "$self_dir/../benchmarks/bench-1bit-pile.sh" \
        /home/bcloud/1bit-systems/benchmarks/bench-1bit-pile.sh \
        /usr/local/share/1bit-systems/benchmarks/bench-1bit-pile.sh \
        /usr/share/1bit-systems/benchmarks/bench-1bit-pile.sh
    do
        if [[ -f "$cand" ]]; then script="$cand"; break; fi
    done
    [[ -n "${script:-}" ]] || die "bench script not found"
    bash "$script"
}

cmd_webui() {
    local action="${1:-up}"
    case "$action" in
        up)
            if pgrep -f 'open-webui.*serve' >/dev/null 2>&1; then
                ok "open-webui already running at $WEBUI_URL"
                return
            fi
            command -v open-webui >/dev/null 2>&1 || die "open-webui not found. Run: uv tool install open-webui"
            say "Starting open-webui on ${WEBUI_HOST}:3000  (1bit.systems-branded, points at $PROXY_URL/v1)"
            WEBUI_NAME="1bit.systems" \
            OPENAI_API_BASE_URL="$PROXY_URL/v1" \
            OPENAI_API_KEY="local-no-auth" \
            ENABLE_OLLAMA_API="False" \
            WEBUI_AUTH="False" \
                nohup open-webui serve --port 3000 --host "$WEBUI_HOST" >"$WEBUI_LOG" 2>&1 &
            for _ in $(seq 1 30); do
                sleep 1
                curl -s --max-time 1 "$WEBUI_URL/health" >/dev/null 2>&1 && { ok "open-webui up at $WEBUI_URL"; return; }
            done
            warn "open-webui didn't respond in 30s — see $WEBUI_LOG"
            ;;
        down)
            if pgrep -f 'open-webui.*serve' >/dev/null 2>&1; then
                pkill -f 'open-webui.*serve'
                ok "open-webui stopped"
            else
                ok "open-webui already stopped"
            fi
            ;;
        status)
            if curl -s --max-time 2 "$WEBUI_URL/health" >/dev/null 2>&1; then
                ok "open-webui: up at $WEBUI_URL"
            else
                warn "open-webui: down"
            fi
            ;;
        *)
            die "usage: 1bit webui [up|down|status]"
            ;;
    esac
}

cmd_gaia() {
    local group="${1:-status}"
    shift || true
    local gaia
    local action="${1:-}"
    case "$group" in
        up|ui)
            if [[ "$group" == "ui" ]]; then
                case "${action:-up}" in
                    up|start) start_gaia ;;
                    down|stop) stop_gaia ;;
                    status) cmd_gaia status ;;
                    *) die "usage: 1bit gaia ui [up|down|status]" ;;
                esac
            else
                start_gaia
            fi
            ;;
        down|stop)
            stop_gaia
            ;;
        status)
            local url
            url="$(gaia_ui_url || true)"
            if pgrep -f 'gaia-agent-ui.AppImage|/\.gaia/venv/bin/gaia chat --ui' >/dev/null 2>&1; then
                ok "GAIA Agent UI running${url:+ at $url}"
                pgrep -af 'gaia-agent-ui.AppImage|/\.gaia/venv/bin/gaia chat --ui' || true
            else
                warn "GAIA Agent UI is not running"
            fi
            [[ -x "$GAIA_APPIMAGE" ]] && ok "AppImage: $GAIA_APPIMAGE" || warn "AppImage missing: $GAIA_APPIMAGE"
            gaia="$(gaia_cli || true)"
            [[ -n "$gaia" ]] && ok "CLI: $gaia" || warn "CLI not found"
            ;;
        api)
            gaia="$(gaia_cli || true)"
            [[ -n "$gaia" ]] || die "GAIA CLI not found"
            action="${action:-status}"
            shift || true
            exec "$gaia" api "$action" --base-url "$GAIA_BASE_URL" "$@"
            ;;
        mcp)
            gaia="$(gaia_cli || true)"
            [[ -n "$gaia" ]] || die "GAIA CLI not found"
            action="${action:-status}"
            shift || true
            exec "$gaia" --base-url "$GAIA_BASE_URL" mcp "$action" "$@"
            ;;
        cli|chat)
            gaia="$(gaia_cli || true)"
            [[ -n "$gaia" ]] || die "GAIA CLI not found"
            exec "$gaia" chat --base-url "$GAIA_BASE_URL" "$@"
            ;;
        logs)
            for log in "$GAIA_ELECTRON_LOG" "$GAIA_LOG"; do
                if [[ -f "$log" ]]; then
                    echo "==> $log"
                    tail -80 "$log"
                fi
            done
            ;;
        *)
            die "usage: 1bit gaia [up|down|status|ui|cli|api|mcp|logs]"
            ;;
    esac
}

cmd_omni() {
    # Locate 1bit-omni.py: prefer adjacent script (dev), then AUR (/usr/share),
    # then manual install.sh path (/usr/local/share).
    local self_dir omni_script
    self_dir="$(dirname "$(readlink -f "$0")")"
    for cand in \
        "$self_dir/1bit-omni.py" \
        /usr/share/1bit-systems/1bit-omni.py \
        /usr/local/share/1bit-systems/1bit-omni.py
    do
        if [[ -f "$cand" ]]; then omni_script="$cand"; break; fi
    done
    [[ -n "${omni_script:-}" ]] || die "1bit-omni.py not found (looked in $self_dir, /usr/share/1bit-systems/, /usr/local/share/1bit-systems/)"

    if [[ $# -eq 0 ]]; then
        cat <<EOF
1bit omni — agentic OpenAI tool-calling loop with our defaults

  Default LLM:    Qwen3.5-35B-A3B-UD-IQ2_XXS  (Tier 2 daily driver)
  Default tools:  generate_image (SD-Turbo)
                  text_to_speech (kokoro-v1)
                  transcribe_audio (Whisper-Tiny)
                  record_microphone
  Plugins:        scripts/omni-plugins/*.json plus installed plugin dirs

Usage:
  1bit omni "Generate an image of X"
  1bit omni "Say 'hello world' out loud"
  1bit omni "Transcribe /path/to/audio.wav"
  1bit omni "Record 5 seconds from the microphone, transcribe it, then make a 3D asset request"
  1bit omni "List OmniRouter models and labels"

Override defaults via env vars:
  ONEBIT_OMNI_LLM, ONEBIT_OMNI_IMAGE, ONEBIT_OMNI_TTS, ONEBIT_OMNI_STT
  ONEBIT_OMNI_OUT (default /tmp/1bit-omni)
  ONEBIT_OMNI_PLUGIN_DIRS (colon-separated plugin dirs)
  ONEBIT_3D_ASSET_RUNNER (optional Hunyuan3D/TRELLIS/SF3D wrapper)
  ONEBIT_3D_ASSET_MODEL (default tencent/Hunyuan3D-2.1)

Outputs land at /tmp/1bit-omni/ (image.png, tts.wav, voice.wav, assets/).
EOF
        return 0
    fi
    exec python3 "$omni_script" "$@"
}

cmd_npu() {
    local model="${1:-$DEFAULT_NPU_MODEL}"
    if pgrep -f 'flm.*serve' >/dev/null 2>&1; then
        ok "flm already serving (pid $(pgrep -f 'flm.*serve' | head -1))"
        return
    fi
    say "Starting flm serve $model"
    # shellcheck disable=SC2086 # flags intentionally split like normal CLI args
    nohup flm serve "$model" $DEFAULT_FLM_FLAGS >"$FLM_LOG" 2>&1 &
    sleep 3
    local port
    port="$(flm port 2>/dev/null | awk '{print $NF}')"
    ok "flm serving $model on :$port (flags: $DEFAULT_FLM_FLAGS, log: $FLM_LOG)"
}

usage() {
    cat <<EOF
1bit — 1bit-systems control plane

Usage:
  1bit up                Start lemond + flm + proxy, open browser, launch GAIA
  1bit down              Stop all services
  1bit status            Show service status
  1bit doctor            Inspect host GPU/runtime/toolbox readiness
  1bit toolbox [list|commands|bootstrap|up|down|status]
                         Manage toolbox-backed llama.cpp backend
  1bit pull <model>      Pull a model (auto-routes NPU vs GPU)
  1bit bench             Run the 1-bit / ternary pile bench
  1bit npu [model]       Start FLM NPU server (default: \$DEFAULT_NPU_MODEL)
  1bit omni "<prompt>"   OmniRouter agentic loop with our defaults
                         (Qwen3.5-35B IQ2_XXS LLM + SD-Turbo + kokoro + whisper)
  1bit webui [up|down|status]  Run Open WebUI on :3000, branded + pointed at proxy
  1bit gaia [up|down|status|ui|cli|api|mcp|logs]
                         Manage AMD GAIA Agent UI / CLI / API / MCP

Endpoints (after \`1bit up\`):
  Unified OpenAI:    $PROXY_URL/v1/   (recommended — both lanes, one shape)
  Lemonade (GPU):    $LEMOND_URL/v1/
  FLM (NPU):         http://127.0.0.1:\$(flm port)/v1/

Override FLM: ONEBIT_NPU_MODEL=qwen3:1.7b ONEBIT_FLM_FLAGS='--embed 1 --asr 1' 1bit up
Override backend: ONEBIT_BACKEND=toolbox ONEBIT_TOOLBOX_MODEL=/path/model.gguf 1bit up
Override GAIA base: GAIA_BASE_URL=http://127.0.0.1:13306/api/v1 1bit gaia cli
EOF
}

case "${1:-}" in
    up)     cmd_up ;;
    down)   cmd_down ;;
    status) cmd_status ;;
    doctor) cmd_doctor ;;
    toolbox) shift; cmd_toolbox "$@" ;;
    pull)   shift; cmd_pull "$@" ;;
    bench)  cmd_bench ;;
    npu)    shift; cmd_npu "$@" ;;
    omni)   shift; cmd_omni "$@" ;;
    webui)  shift; cmd_webui "$@" ;;
    gaia)   shift; cmd_gaia "$@" ;;
    -h|--help|help|"") usage ;;
    *)      die "unknown subcommand: $1 (try \`1bit help\`)" ;;
esac
