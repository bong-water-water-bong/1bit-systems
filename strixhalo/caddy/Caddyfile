# halo-ai reverse proxy — 127.0.0.1:8080 (bitnet_decode) -> HTTPS
# Hostnames: the machine's .local (mDNS/Bonjour) and explicit LAN IP fallback.
{
    # Internal CA — Caddy issues self-signed certs trusted via its root.
    # Trust /var/lib/caddy/.local/share/caddy/pki/authorities/local/root.crt
    # on client machines once.
    admin off
}

# Per-user bearer matcher — regenerated from /etc/caddy/bearers.txt by
# strixhalo/bin/halo-caddy-bearers.sh. Defines (bearer_matcher) snippet
# so every gated route can `import bearer_matcher` and share one regex.
# On a fresh box, bearers.conf is empty / placeholder; halo-mesh-invite.sh
# creates bearers.txt on first invite and rebuilds this snippet.
import /etc/caddy/bearers.conf

strixhalo.local, 10.0.0.10 {
    tls internal

    # Per-user bearers in /etc/caddy/bearers.txt → /etc/caddy/bearers.conf.
    # Defines @authorized for this site; nested handle blocks inherit it.
    import bearer_matcher

    # / + landing assets + live status → halo-landing (127.0.0.1:8190).
    # No bearer — marketing page, LAN-only via hostname.
    @landing path / /style.css /_health /_live/*
    handle @landing {
        reverse_proxy 127.0.0.1:8190 {
            flush_interval -1
        }
    }

    # /mancave/* → static launcher page (no auth — LAN only via hostname).
    handle_path /mancave/* {
        root * /srv/www/mancave
        file_server
    }

    # /v2/* → strix-server (gen-2 Rust, 127.0.0.1:8180). Same bearer gate as /v1/*.
    # Runs side-by-side with gen-1 /v1/* (bitnet_decode :8080) during burn-in.
    handle_path /v2/* {
        handle @authorized {
            reverse_proxy 127.0.0.1:8180 {
                flush_interval -1
                transport http {
                    read_timeout 10m
                    write_timeout 10m
                }
            }
        }
        handle {
            respond "Unauthorized — bearer token required" 401
        }
    }

    # /lemon/* → lemonade-server (lemond daemon, 127.0.0.1:8000). Bearer-gated.
    handle_path /lemon/* {
        handle @authorized {
            reverse_proxy 127.0.0.1:8000 {
                flush_interval -1
                transport http {
                    read_timeout 10m
                    write_timeout 10m
                }
            }
        }
        handle {
            respond "Unauthorized — bearer token required" 401
        }
    }

    # /sd/* → sd-server (stable-diffusion.cpp, 127.0.0.1:8081). Strip prefix.
    handle_path /sd/* {
        handle @authorized {
            reverse_proxy 127.0.0.1:8081 {
                flush_interval -1
                transport http {
                    # SDXL 1024×1024 20-step = ~207s; give headroom.
                    read_timeout 15m
                    write_timeout 15m
                }
            }
        }
        handle {
            respond "Unauthorized — bearer token required" 401
        }
    }

    # /whisper/* → halo-whisper STT (127.0.0.1:8082). Bearer-gated.
    # Consumed by studio-site/voice/ mobile web app.
    handle_path /whisper/* {
        handle @authorized {
            reverse_proxy 127.0.0.1:8082 {
                flush_interval -1
                transport http {
                    read_timeout 5m
                    write_timeout 5m
                }
            }
        }
        handle {
            respond "Unauthorized — bearer token required" 401
        }
    }

    # /kokoro/* → halo-kokoro TTS (127.0.0.1:8083). Bearer-gated.
    # One sentence per POST; /voice/ splits SSE on sentence boundary.
    handle_path /kokoro/* {
        handle @authorized {
            reverse_proxy 127.0.0.1:8083 {
                flush_interval -1
                transport http {
                    read_timeout 2m
                    write_timeout 2m
                }
            }
        }
        handle {
            respond "Unauthorized — bearer token required" 401
        }
    }

    handle @authorized {
        # Pass-through with SSE streaming support — bitnet_decode sends
        # text/event-stream on /v1/chat/completions when stream=true.
        reverse_proxy 127.0.0.1:8080 {
            flush_interval -1
            transport http {
                read_timeout 10m
                write_timeout 10m
            }
        }
    }

    handle {
        respond "Unauthorized — bearer token required" 401
    }

    log {
        output file /var/log/caddy/halo-access.log {
            roll_size 10MiB
            roll_keep 5
        }
    }
}

# Headscale coordination server — no bearer gate (tailscale has its own auth).
headscale.strixhalo.local, 10.0.0.10:8443 {
    tls internal
    reverse_proxy 127.0.0.1:8380
}

# LAN-only bootstrap server — unauthenticated, serves helper scripts + CA.
http://10.0.0.10:8099 {
    root * /var/www/halo-bootstrap
    file_server browse
}
