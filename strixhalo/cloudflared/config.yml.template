# cloudflared tunnel config for halo-ai.studio subdomains
#
# BEFORE USING:
#   1. cloudflared tunnel login                         # browser: authenticate CF account
#   2. cloudflared tunnel create halo-ai-studio         # returns a UUID, writes ~/.cloudflared/<UUID>.json
#   3. cloudflared tunnel route dns halo-ai-studio api.halo-ai.studio
#   4. cloudflared tunnel route dns halo-ai-studio audio.halo-ai.studio
#   5. cp ~/.cloudflared/config.yml.template ~/.cloudflared/config.yml
#   6. sed -i "s/PLACEHOLDER_UUID/<UUID from step 2>/" ~/.cloudflared/config.yml
#
# Then: systemctl --user enable --now strix-cloudflared.service

tunnel: PLACEHOLDER_UUID
credentials-file: /home/bcloud/.cloudflared/PLACEHOLDER_UUID.json

# One tunnel, multiple hostnames.
# CF terminates TLS at the edge; we forward plaintext HTTP to loopback.
ingress:
  # Primary OpenAI-compat endpoint — completions / embeddings / models.
  # Hermes users can `hermes model` at https://api.halo-ai.studio/v1 and
  # reach our native-HIP inference.
  - hostname: api.halo-ai.studio
    service: http://127.0.0.1:8180
    originRequest:
      connectTimeout: 30s
      noTLSVerify: true

  # Audio lane — halo-echo WebSocket voice server (Opus frames over ws).
  # halo-echo must be running under strix-echo.service on :8085.
  # "the-architect" audio business subdomain (2026-04-20 lock-in).
  - hostname: audio.halo-ai.studio
    service: http://127.0.0.1:8085
    originRequest:
      connectTimeout: 30s
      noTLSVerify: true

  - service: http_status:404
