[Unit]
Description=1bit-halo-patreon poller (new-patron Discord announcer)

[Timer]
# 2 min after boot, then every 15 min. Patreon membership churn is
# slow (manual sign-ups); a tighter interval just wastes API budget
# without shrinking the window between a new patron and their welcome.
OnBootSec=2min
OnUnitActiveSec=15min
Persistent=true
Unit=1bit-halo-patreon.service

[Install]
WantedBy=timers.target
