[Unit]
Description=1bit-sd — stable-diffusion.cpp native HIP server (SDXL + Wan 2.2 TI2V-5B)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/1bit-sd-server \
    -l 127.0.0.1 \
    --listen-port 1234 \
    --model %h/.local/share/1bit/models/sdxl-q8/model.gguf
Restart=on-failure
RestartSec=5s
Nice=5

[Install]
WantedBy=default.target
