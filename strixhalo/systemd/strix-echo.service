[Unit]
Description=1bit-echo WebSocket voice server (:8085)
After=network-online.target strix-server.service strix-kokoro.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=%h/.local/bin/1bit-echo --bind-host 127.0.0.1 --bind-port 8085 --codec pcm
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
