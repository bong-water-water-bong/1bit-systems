[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = xrt

[Action]
Description = 1bit systems: re-patching /usr/share/cmake/XRT/xrt-targets.cmake (CachyOS xrt ships broken cmake — see memory project_strix_halo_hardware.md)
When = PostTransaction
Exec = /usr/local/sbin/1bit-xrt-cmake-patch.sh
