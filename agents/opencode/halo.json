{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "halo-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "halo-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8180/v1",
        "apiKey": "${HALO_API_KEY}"
      },
      "models": {
        "halo-1bit-2b-4t-q": {
          "name": "halo 1bit 2b 4t-q (Sherry 1.25 bpw)",
          "contextWindow": 8192
        },
        "halo-1bit-2b-4t-bf16": {
          "name": "halo 1bit 2b 4t (bf16 baseline)",
          "contextWindow": 8192
        }
      }
    }
  },
  "model": "halo-local/halo-1bit-2b-4t-q"
}
