#!/usr/bin/env bash
# AppRun — entry point for the 1bit-systems AppImage.
#
# Dispatches to one of the bundled binaries in usr/bin/ based on $ARGV0
# (the name AppImage was invoked as — i.e. if the operator symlinks the
# AppImage to `/usr/local/bin/1bit`, $ARGV0 ends up as "1bit" and we run
# the `1bit` CLI; if they symlink to `1bit-halo-helm-tray`, that runs).
#
# Invoked directly as `1bit-systems-0.1.0-x86_64.AppImage`, we:
#   - print a short "what's inside" message
#   - exec the `1bit` CLI with --help so the operator has something to read
#
# $ARGV0 semantics: set by AppImage runtime to the symlink basename the
# user ran. Falls back to the AppImage name itself if unsymlinked. We
# normalise trailing `.AppImage` + architecture suffixes off it.
#
# Rule A: this is a shell launcher on the install path, not a service —
# allowed. No Python, no interpreter runtime bundled.

set -eu

# $APPDIR is set by the AppImage runtime to the mounted AppDir root.
# Fallback: resolve relative to this script, for running AppDir unpackaged.
HERE="${APPDIR:-$(cd "$(dirname "$(readlink -f "$0")")" && pwd)}"
BIN="$HERE/usr/bin"

# Derive the dispatch name from $ARGV0. AppImage sets this to the symlink
# basename when invoked via a symlink; when invoked as the raw AppImage it
# points at the AppImage path itself.
argv0="${ARGV0:-$0}"
name="$(basename "$argv0")"

# Strip the AppImage-side decorations so symlinks don't need to spell the
# exact artifact name to resolve to `1bit`.
name="${name%.AppImage}"
name="${name%-x86_64}"
case "$name" in
    1bit-systems-*)
        # Raw AppImage with version tag — default to the CLI entrypoint.
        name="1bit-systems"
        ;;
esac

exec_bundled() {
    local bin="$BIN/$1"
    shift
    if [[ ! -x "$bin" ]]; then
        printf '1bit-systems: bundled binary not found: %s\n' "$bin" >&2
        exit 127
    fi
    exec "$bin" "$@"
}

case "$name" in
    # Primary CLI entrypoint. `1bit install core`, `1bit status`, etc.
    1bit)
        exec_bundled 1bit "$@"
        ;;

    # Desktop / tray.
    1bit-helm)
        exec_bundled 1bit-helm "$@"
        ;;
    1bit-halo-helm-tray|1bit-tray)
        exec_bundled 1bit-halo-helm-tray "$@"
        ;;

    # HTTP + routing services.
    onebit-server|1bit-server)
        exec_bundled onebit-server "$@"
        ;;
    1bit-landing)
        exec_bundled 1bit-landing "$@"
        ;;
    1bit-lemonade)
        exec_bundled 1bit-lemonade "$@"
        ;;

    # Agent bus watchers.
    1bit-watch-discord)
        exec_bundled 1bit-watch-discord "$@"
        ;;
    1bit-watch-github)
        exec_bundled 1bit-watch-github "$@"
        ;;

    # MCP bridges.
    1bit-mcp)
        exec_bundled 1bit-mcp "$@"
        ;;
    1bit-mcp-discord)
        exec_bundled 1bit-mcp-discord "$@"
        ;;
    1bit-mcp-linuxgsm)
        exec_bundled 1bit-mcp-linuxgsm "$@"
        ;;

    # Voice lane.
    1bit-voice)
        exec_bundled 1bit-voice "$@"
        ;;
    1bit-echo)
        exec_bundled 1bit-echo "$@"
        ;;
    1bit-whisper)
        exec_bundled 1bit-whisper "$@"
        ;;
    1bit-kokoro)
        exec_bundled 1bit-kokoro "$@"
        ;;

    # Ops lane.
    1bit-halo-pkg)
        exec_bundled 1bit-halo-pkg "$@"
        ;;
    1bit-halo-power)
        exec_bundled 1bit-halo-power "$@"
        ;;
    1bit-halo-ralph)
        exec_bundled 1bit-halo-ralph "$@"
        ;;

    # Explicit --list — dump what's inside.
    --list|-l)
        printf '1bit-systems AppImage — bundled binaries (symlink the AppImage to any of these to launch):\n\n'
        for f in "$BIN"/*; do
            [[ -x "$f" && -f "$f" ]] && printf '  %s\n' "$(basename "$f")"
        done
        printf '\nRun --help against any of them for per-binary usage.\n'
        exit 0
        ;;

    # Default: unsymlinked AppImage was invoked. Print a greeter + defer
    # to `1bit --help` so the user has something concrete to read.
    1bit-systems|*)
        cat <<'EOF'
1bit-systems — local AI inference on Strix Halo (single-file AppImage).

This AppImage bundles the user-facing Rust binaries from the 1bit workspace.
ROCm / librocm_cpp.so is NOT bundled — install via `./install.sh` on the host.

Symlink this AppImage to any of the following names to launch that binary:

    1bit                    # unified ops CLI (status / doctor / install / chat / …)
    1bit-helm               # egui/eframe desktop client
    1bit-halo-helm-tray     # Plasma SNI tray icon
    1bit-watch-discord      # Discord agent watcher
    1bit-voice              # voice loop orchestrator
    …and more (run with --list to see all bundled binaries)

Falling through to `1bit --help`.

EOF
        exec_bundled 1bit --help
        ;;
esac
