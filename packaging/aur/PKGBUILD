# Maintainer: bong-water-water-bong <277547417+bong-water-water-bong@users.noreply.github.com>
#
# Arch User Repository (AUR) PKGBUILD for 1bit-systems.
#
# Four packages in this tree:
#   1bit-systems-bin   — prebuilt AppImage (fast install, no compile)
#   1bit-systems       — builds from source via cargo (slower, matches
#                        rocm-cpp host install)
#
# Publish to AUR via (once per bump):
#   makepkg --printsrcinfo > .SRCINFO
#   git commit -am "v$pkgver"
#   git push aur master
#
# Rule A: only Rust orchestration binaries land in the package. ROCm /
# librocm_cpp.so / model weights are handled by `install.sh` on first
# run of `1bit install all`.

pkgname=1bit-systems
pkgver=0.1.8
pkgrel=1
pkgdesc="Local AI inference on Strix Halo — LLM + TTS + STT + image + video + NPU"
arch=('x86_64')
url="https://1bit.systems"
license=('MIT')
depends=(
    'glibc'
    'gcc-libs'
    # Soft runtime deps — only hit once the user runs `1bit install all`.
    # We list them so pacman warns users on install rather than at first
    # kernel launch.
    'rocm-hip-libraries'
    'rocm-core'
    'vulkan-icd-loader'
    'xrt'
)
optdepends=(
    'rocm-hip-sdk: building custom HIP kernels via rocm-cpp'
    'python: ironenv NPU kernel authoring (dev only, never runtime)'
    'hf-cli: first-run model download'
)
makedepends=(
    'rust>=1.86'
    'cargo'
    'cmake'
    'git'
)
source=("$pkgname-$pkgver.tar.gz::https://github.com/bong-water-water-bong/1bit-systems/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')  # Auto-fill via `updpkgsums` on release day.

prepare() {
    cd "$pkgname-$pkgver"
    # Vendor crates for reproducible builds.
    cargo fetch --locked
}

build() {
    cd "$pkgname-$pkgver"
    # Skip GPU-feature crates on public AUR builds — end user enables them
    # via `1bit install all` after ROCm host prereqs are in place.
    cargo build --release --frozen \
        -p onebit-cli \
        -p onebit-power \
        -p onebit-watchdog \
        -p onebit-helm \
        -p onebit-voice \
        -p onebit-echo \
        -p onebit-mcp
}

check() {
    cd "$pkgname-$pkgver"
    cargo test --release --frozen \
        -p onebit-cli \
        -p onebit-power \
        -p onebit-watchdog \
        -p onebit-voice
}

package() {
    cd "$pkgname-$pkgver"
    install -Dm755 "target/release/1bit"             "$pkgdir/usr/bin/1bit"
    install -Dm755 "target/release/1bit-power"       "$pkgdir/usr/bin/1bit-power"
    install -Dm755 "target/release/1bit-watchdog"    "$pkgdir/usr/bin/1bit-watchdog"
    install -Dm755 "target/release/1bit-helm"        "$pkgdir/usr/bin/1bit-helm"
    install -Dm755 "target/release/1bit-voice"       "$pkgdir/usr/bin/1bit-voice"
    install -Dm755 "target/release/1bit-echo"        "$pkgdir/usr/bin/1bit-echo"
    install -Dm755 "target/release/1bit-mcp"         "$pkgdir/usr/bin/1bit-mcp"

    # Systemd user units — ship alongside the binaries so `1bit install`
    # can symlink them into $XDG_CONFIG_HOME/systemd/user/.
    for unit in strixhalo/systemd/user/1bit-*.service strixhalo/systemd/user/1bit-*.timer; do
        [[ -f "$unit" ]] || continue
        install -Dm644 "$unit" "$pkgdir/usr/lib/systemd/user/$(basename "$unit")"
    done

    # Docs.
    install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 LICENSE   "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
