post_install() {
  cat <<'MSG'
==> 1bit-systems-bin AUR packaging is currently deprecated.
==> Use the repository install.sh for the supported GAIA + Lemonade + FastFlowLM stack.
==> See docs/aur.md and packaging/binary/README.md before publishing this package.
MSG
}

post_upgrade() {
  post_install
}

post_remove() {
  cat <<'MSG'
==> /etc/security/limits.d/99-1bit-systems.conf may remain installed.
==> Remove it manually only if no local AI runtime depends on unlimited memlock.
MSG
}
