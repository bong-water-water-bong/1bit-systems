# Maintainer: bong-water-water-bong <277547417+bong-water-water-bong@users.noreply.github.com>
# shellcheck disable=SC2034,SC2148,SC2154

pkgname=1bit-systems-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="Local 1-bit / 1.58-bit ternary LLM inference on AMD Strix Halo (AppImage)"
arch=('x86_64')
url="https://github.com/bong-water-water-bong/1bit-systems"
license=('MIT')
depends=('fuse2' 'rocm-hip-runtime' 'rocm-core')
optdepends=(
    'rocminfo: recommended, used by preflight gates'
    'amdxdna-dkms: XDNA2 NPU support (0.1.x glue kernel lands later)'
    'xrt: runtime dispatch for XDNA2 NPU'
)
provides=('1bit-systems')
conflicts=('1bit-systems' '1bit-systems-git')
source=("1bit-systems-${pkgver}-x86_64.AppImage::https://github.com/bong-water-water-bong/1bit-systems/releases/download/v${pkgver}/1bit-systems-${pkgver}-x86_64.AppImage")
sha256sums=('8a964f89bdef68ed914c04fcf23092ac642c424bb70f74dc10e8558e93b94036')
noextract=("1bit-systems-${pkgver}-x86_64.AppImage")

package() {
    cd "$srcdir"

    # Drop the AppImage into /opt so it's not in $PATH twice if the
    # user also has a local build at ~/.local/bin/1bit.
    install -Dm755 "1bit-systems-${pkgver}-x86_64.AppImage" \
        "$pkgdir/opt/1bit-systems/1bit-systems-${pkgver}.AppImage"

    # Symlink the primary entrypoint into /usr/bin. AppImage picks
    # up the right subcommand via $ARGV0 dispatch; bare `1bit` runs
    # the CLI, other names route to the other bundled binaries.
    install -dm755 "$pkgdir/usr/bin"
    ln -sfn "/opt/1bit-systems/1bit-systems-${pkgver}.AppImage" \
        "$pkgdir/usr/bin/1bit"

    # Bundled-binary ARGV0 dispatch — expose the ones users actually
    # want on $PATH. Add more as they stabilize.
    local argv0_binaries=(
        1bit-helm
        1bit-halo-helm-tray
        1bit-voice
        1bit-echo
        1bit-mcp
        1bit-power
        1bit-watchdog
        1bit-pkg
        1bit-landing
        1bit-server-real
    )
    for b in "${argv0_binaries[@]}"; do
        ln -sfn "/opt/1bit-systems/1bit-systems-${pkgver}.AppImage" \
            "$pkgdir/usr/bin/$b"
    done

    # Desktop entry for GUI launchers (helm, helm-tray).
    install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/io.onebit.Systems.desktop" <<DESKTOP
[Desktop Entry]
Type=Application
Name=1bit Systems
GenericName=Local AI Inference
Comment=Native 1.58-bit ternary LLMs on Strix Halo
Exec=1bit chat
Terminal=true
Categories=Development;Science;
Keywords=llm;ai;bitnet;ternary;strix-halo;
Icon=io.onebit.Systems
DESKTOP

    # License file for pacman -Ql / AUR auditors.
    install -dm755 "$pkgdir/usr/share/licenses/$pkgname"
    cat >"$pkgdir/usr/share/licenses/$pkgname/LICENSE" <<'LIC'
MIT — see https://github.com/bong-water-water-bong/1bit-systems/blob/main/LICENSE
Ternary model weights follow their upstream licenses (MIT for Microsoft
BitNet-b1.58-2B-4T).
LIC
}

# vim: set ts=4 sw=4 et:
