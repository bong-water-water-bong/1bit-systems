#!/usr/bin/make -f
# See debhelper(7)
#
# Rust gut 2026-04-26: this script used to drive cargo. The whole
# orchestration tower is C++23 in `cpp/` now. We invoke
# `cmake --preset release-strix` instead.

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export CXXFLAGS += -march=x86-64-v3

%:
	dh $@

override_dh_auto_configure:
	cd cpp && cmake --preset release-strix

override_dh_auto_build:
	cd cpp && cmake --build --preset release-strix

override_dh_auto_test:
	cd cpp && ctest --preset release-strix

override_dh_auto_install:
	mkdir -p debian/1bit-systems/usr/bin
	install -m755 cpp/build/strix/cli/1bit                 debian/1bit-systems/usr/bin/
	install -m755 cpp/build/strix/power/1bit-power         debian/1bit-systems/usr/bin/
	install -m755 cpp/build/strix/watchdog/1bit-watchdog   debian/1bit-systems/usr/bin/
	install -m755 cpp/build/strix/helm/1bit-helm           debian/1bit-systems/usr/bin/
	install -m755 cpp/build/strix/voice/1bit-voice         debian/1bit-systems/usr/bin/
	install -m755 cpp/build/strix/echo/1bit-echo           debian/1bit-systems/usr/bin/
	install -m755 cpp/build/strix/mcp/1bit-mcp             debian/1bit-systems/usr/bin/
	mkdir -p debian/1bit-systems/lib/systemd/user
	for unit in strixhalo/systemd/user/1bit-*.service strixhalo/systemd/user/1bit-*.timer; do \
		[ -f "$$unit" ] && install -m644 "$$unit" debian/1bit-systems/lib/systemd/user/ ; \
	done
