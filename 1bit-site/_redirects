# Cloudflare Pages — redirect rules
# Format: <from> <to> <status>

# Canonicalize the preview domain to production when it eventually flips.
# Off by default; uncomment after hard-push.
# https://*.1bit-systems.pages.dev/*  https://1bit.systems/:splat  301

# ──────────────────────────────────────────────────────────────────────
# Multi-domain routing — four apex domains share this Pages deploy.
# Cloudflare Pages routes by Host header; these 200-status rewrites keep
# the URL bar on the apex while serving the matching subtree.

https://1bit.music/*        /music/:splat    200
https://www.1bit.music/*    https://1bit.music/:splat        301

https://1bit.video/*        /video/:splat    200
https://www.1bit.video/*    https://1bit.video/:splat        301

https://1bit.stream/*       /stream/:splat   200
https://www.1bit.stream/*   https://1bit.stream/:splat       301

https://1bit.audio/*        /compress/:splat 200
https://www.1bit.audio/*    https://1bit.audio/:splat        301
# Note: /audio/ subtree is already used by the Kokoro TTS sampler from the
# original 1bit.systems site. The 1bit.audio apex maps to /compress/ instead.

# waterbon.me — founder / personal identity page
https://waterbon.me/*       /me/:splat       200
https://www.waterbon.me/*   https://waterbon.me/:splat       301

# 1bit.arcade — WASM demos / interactive cabinet
https://1bit.arcade/*       /arcade/:splat   200
https://www.1bit.arcade/*   https://1bit.arcade/:splat       301

